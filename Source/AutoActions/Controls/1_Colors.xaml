<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!--  LIGHT THEME PALETTE (default, baked into AppResources.xaml)   -->
    <!--  Red accent identity preserved; neutrals modernized (Fluent).  -->
    <!--  The matching dark overrides live in Theming/DarkColors.xaml   -->
    <!--  and are merged on top at startup when Windows is in dark mode.-->
    <!-- ============================================================= -->

    <!-- Accent / status family (kept identical in light & dark) -->
    <Color x:Key="ActiveColor">#21C67D</Color>
    <Color x:Key="AccentColor">#FF6666</Color>
    <Color x:Key="ControlMouseOverColor">#FF8585</Color>
    <Color x:Key="ControlPressedColor">#E85B5B</Color>
    <Color x:Key="SelectedBackgroundColor">#FF7A7A</Color>

    <!-- Neutral surfaces (overridden in dark) -->
    <Color x:Key="WindowColor">#FBFBFB</Color>
    <Color x:Key="ControlLightColor">#FFFFFF</Color>
    <Color x:Key="ControlMediumColor">#E2E2E2</Color>
    <Color x:Key="IconBackgroundColor">#ECECEC</Color>
    <Color x:Key="SelectedUnfocusedColor">#E6E6E6</Color>

    <!-- Text / glyph (overridden in dark) -->
    <Color x:Key="ForegroundColor">#1F1F1F</Color>
    <Color x:Key="SubtleForegroundColor">#6B6B6B</Color>
    <Color x:Key="GlyphColor">#5A5A5A</Color>
    <!-- Text drawn on top of the red accent - stays light in both themes -->
    <Color x:Key="ButtonForegroundColor">#FFFFFF</Color>

    <!-- Disabled states (overridden in dark) -->
    <Color x:Key="DisabledForegroundColor">#B4B4B4</Color>
    <Color x:Key="DisabledControlDarkColor">#9A9A9A</Color>
    <Color x:Key="DisabledBorderColor">#D4D4D4</Color>

    <!-- ===================== Brushes ===================== -->

    <!-- Neutral brushes (kept in sync with the dark overrides) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="ControlLightBrush" Color="{StaticResource ControlLightColor}"/>
    <SolidColorBrush x:Key="IconBackgroundBrush" Color="{StaticResource IconBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlMediumColor}"/>
    <SolidColorBrush x:Key="GlyphBrush" Color="{StaticResource GlyphColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleForegroundBrush" Color="{StaticResource SubtleForegroundColor}"/>

    <!-- Accent / status brushes (identical in dark) -->
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="{StaticResource ButtonForegroundColor}"/>
    <SolidColorBrush x:Key="ActiveBrush" Color="{StaticResource ActiveColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="HighlightedBrush" Color="{StaticResource SelectedBackgroundColor}"/>
    <SolidColorBrush x:Key="MouseOverBrush" Color="{StaticResource ControlMouseOverColor}"/>
    <SolidColorBrush x:Key="InactiveAccentBrush">#AD7B7B</SolidColorBrush>
    <SolidColorBrush x:Key="HighlightedInactiveAccentBrush" Color="#95BFDB"/>

    <!-- WinUI-style navigation selection (subtle neutral fill; overridden in dark) -->
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="#0A000000"/>
    <SolidColorBrush x:Key="NavItemSelectedBrush" Color="#14000000"/>

    <!-- Disabled brush (overridden in dark) -->
    <SolidColorBrush x:Key="DisabledAccentBrush" Color="{StaticResource DisabledControlDarkColor}"/>

    <!-- Scrollbar brushes (overridden in dark) -->
    <SolidColorBrush x:Key="ScrollBrush">#C9C9C9</SolidColorBrush>
    <SolidColorBrush x:Key="MouseOverScrollBrush">#ABABAB</SolidColorBrush>
    <SolidColorBrush x:Key="DragScrollBrush">#8A8A8A</SolidColorBrush>

    <StaticResource x:Key="ButtonBackgroundBrush" ResourceKey="AccentBrush"/>

</ResourceDictionary>
