<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!--  DARK THEME OVERRIDES                                          -->
    <!--  Merged on top of AppResources.xaml at startup (App.xaml.cs)   -->
    <!--  ONLY when Windows reports a dark app theme.                   -->
    <!--                                                                -->
    <!--  Contains ONLY the neutral / text / disabled / scrollbar keys  -->
    <!--  that must differ from light. The red accent + status colors   -->
    <!--  are intentionally NOT redefined here, so they fall through to -->
    <!--  the base (light) palette and stay identical in both themes.   -->
    <!--                                                                -->
    <!--  For an override to take effect, the template/view that uses   -->
    <!--  the key must reference it via {DynamicResource ...}. Static    -->
    <!--  references resolve once at load and will NOT pick up dark.     -->
    <!-- ============================================================= -->

    <!-- Neutral surfaces -->
    <Color x:Key="WindowColor">#1F1F1F</Color>
    <Color x:Key="ControlLightColor">#2B2B2B</Color>
    <Color x:Key="ControlMediumColor">#3A3A3A</Color>
    <Color x:Key="IconBackgroundColor">#333333</Color>
    <Color x:Key="SelectedUnfocusedColor">#3A3A3A</Color>

    <!-- Text / glyph -->
    <Color x:Key="ForegroundColor">#F0F0F0</Color>
    <Color x:Key="SubtleForegroundColor">#A6A6A6</Color>
    <Color x:Key="GlyphColor">#C8C8C8</Color>

    <!-- Disabled states -->
    <Color x:Key="DisabledForegroundColor">#6E6E6E</Color>
    <Color x:Key="DisabledControlDarkColor">#6A6A6A</Color>
    <Color x:Key="DisabledBorderColor">#4A4A4A</Color>

    <!-- ===================== Brushes ===================== -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="ControlLightBrush" Color="{StaticResource ControlLightColor}"/>
    <SolidColorBrush x:Key="IconBackgroundBrush" Color="{StaticResource IconBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlMediumColor}"/>
    <SolidColorBrush x:Key="GlyphBrush" Color="{StaticResource GlyphColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleForegroundBrush" Color="{StaticResource SubtleForegroundColor}"/>
    <SolidColorBrush x:Key="DisabledAccentBrush" Color="{StaticResource DisabledControlDarkColor}"/>

    <!-- WinUI-style navigation selection (subtle white fill on dark surfaces) -->
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="NavItemSelectedBrush" Color="#24FFFFFF"/>

    <!-- Scrollbar (lighter grays read better on a dark track) -->
    <SolidColorBrush x:Key="ScrollBrush">#4A4A4A</SolidColorBrush>
    <SolidColorBrush x:Key="MouseOverScrollBrush">#5E5E5E</SolidColorBrush>
    <SolidColorBrush x:Key="DragScrollBrush">#6E6E6E</SolidColorBrush>

</ResourceDictionary>
