<corewpf:MainWindowBase x:Class="AutoActions.Views.AutoActionsMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:corewpf="clr-namespace:CodectoryCore.UI.Wpf;assembly=CodectoryCore.UI.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ctrl="clr-namespace:Itenso.Windows.Controls.ListViewLayout;assembly=CodectoryCore.UI.Wpf"
        xmlns:p="clr-namespace:AutoActions.Properties"
        xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
        xmlns:pres="clr-namespace:AutoActions.ProjectResources;assembly=AutoActions.ProjectResources"
        xmlns:dsp="clr-namespace:AutoActions.Displays;assembly=AutoActions.Displays"
        xmlns:local="clr-namespace:AutoActions.Views"
        xmlns:root="clr-namespace:AutoActions"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="AutoActions" Name="MainWindow" MinHeight="480" MinWidth="480" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" FontFamily="Segoe UI Variable Text, Segoe UI" Closing="Window_Closing"  Visibility="{Binding ShowView, Mode=TwoWay, Converter={StaticResource VisibilityBooleanConverter}}"
         Loaded="MainWindow_Loaded">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding ClosingCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Window.DataContext>
        <root:AutoActionsDaemon/>
    </Window.DataContext>
    <corewpf:MainWindowBase.DialogService >
        <Binding>
            <Binding.Source>
                <StaticResource ResourceKey="DialogService" />
            </Binding.Source>
        </Binding>
    </corewpf:MainWindowBase.DialogService>
    <Window.Resources>

        <DataTemplate x:Key="AssignmentTemplate" DataType="ApplicationProfileAssignment">
            <Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=PriorityColumn, Path=ActualWidth}"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="0" Text="{Binding Position}" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Image Grid.Column="1" Source="{Binding Application.Icon, Converter={StaticResource BitmapToBitmapImageConverter}}" Width="50" Height="50"  Stretch="Fill"></Image>
                    <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="2" Text="{Binding Application.DisplayName}" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ComboBox Grid.Column="3" SelectedValuePath="Name" DisplayMemberPath="Name" SelectedValue="{Binding Profile, Mode=TwoWay}" SelectedItem="{Binding Profile, Mode=TwoWay}" ItemsSource="{Binding ElementName=MainWindow , Path=DataContext.Settings.ApplicationProfiles}" VerticalAlignment="Center" />
                </Grid>
            </Border>

        </DataTemplate>

        <!-- ===== Fluent left-navigation look (re-templated TabControl) ===== -->
        <!-- A single nav entry: accent selection bar + icon/text, hover highlight. -->
        <Style x:Key="NavTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="4,2" MinHeight="40">
                            <Grid>
                                <Border x:Name="Indicator" Width="3" Height="16" CornerRadius="1.5" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <ContentPresenter ContentSource="Header" Margin="16,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavItemSelectedBrush}"/>
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The container: left nav pane (surface) + content area. -->
        <Style x:Key="NavTabControl" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource ControlLightBrush}">
                                <TabPanel IsItemsHost="True" Margin="6,12"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" ContentSource="SelectedContent" Margin="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid x:Name="MainGrid">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>
            <TabControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" TabStripPlacement="Left" Style="{StaticResource NavTabControl}" ItemContainerStyle="{StaticResource NavTabItem}" BorderThickness="0">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Home24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static pres:ProjectLocales.Status}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <local:StatusView DataContext="{Binding}"/>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Options24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static pres:ProjectLocales.Profiles}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <local:ProfileManagerView   DataContext="{Binding ElementName=MainWindow , Path=DataContext}"/>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Apps24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static pres:ProjectLocales.Applications}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid x:Name="AssignmentsGrid" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition  Width="Auto"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"  />

                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"  />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource SubTitleTextBlock}"  Grid.Column="0" Grid.ColumnSpan="3" Grid.Row ="0"   Text="{x:Static pres:ProjectLocales.Applications}"/>

                        <ui:Card Grid.ColumnSpan="3" Grid.Row ="1"  Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
                        <Grid Grid.IsSharedSizeScope="True" Grid.ColumnSpan="3" Grid.Row ="1"  Margin="15" >
                            <ListBox Name="ApplicationList" Background="Transparent" ItemContainerStyle="{StaticResource ListBoxItemStyle }"  ItemsSource="{Binding Settings.ApplicationProfileAssignments}" HorizontalContentAlignment="Stretch" >
                                <ListBox.Template>
                                    <ControlTemplate>
                                        <DockPanel LastChildFill="True">

                                            <Grid DockPanel.Dock="Top" Height="Auto" Margin="0,0,0,5" >
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition SharedSizeGroup="IconColumn" MinWidth="60"/>
                                                    <ColumnDefinition SharedSizeGroup="ApplicationColumn" MinWidth="220"/>
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="0" FontWeight="Bold"  FontSize="14" Margin="5,0" Text="{x:Static pres:ProjectLocales.Icon}"/>
                                                <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="1" FontWeight="Bold" FontSize="14"   Margin="5,0" Text="{x:Static pres:ProjectLocales.Application}"/>
                                                <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="2" FontWeight="Bold" FontSize="14"   Margin="5,0" Text="{x:Static pres:ProjectLocales.Profile}"/>
                                            </Grid>
                                            <Grid>
                                                <Grid Margin="0,5">
                                                    <ScrollViewer>
                                                    <ItemsPresenter Margin="5"></ItemsPresenter>
                                                </ScrollViewer>
                                                    </Grid>
                                            </Grid>

                                        </DockPanel>

                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock/>
                                            <Border>
                                            <Grid Margin="0,2"  >
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition SharedSizeGroup="IconColumn" Width="Auto"/>
                                                    <ColumnDefinition SharedSizeGroup="ApplicationColumn" Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                    <Border Width="50" Grid.Column="0"  CornerRadius="{StaticResource DefaultCornerRadius}" Background="{StaticResource IconBackgroundBrush}">
                                                    <Border  Height="49" Width="49" CornerRadius="{StaticResource DefaultCornerRadius}" Margin="1">
                                                        <Border.Background>
                                                            <ImageBrush Stretch="Fill" ImageSource="{Binding Application.Icon, Converter={StaticResource BitmapToBitmapImageConverter}}"/>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                                <TextBlock Style="{StaticResource DefaultTextBlock}"  Grid.Column="1" Width="Auto"  Padding="5,0" Text="{Binding Application.DisplayName}" VerticalAlignment="Center" HorizontalAlignment="Stretch"  />
                                                <ComboBox MinHeight="35" VerticalContentAlignment="Stretch" Grid.Column="2" Width="Auto"  Margin="5,0,10,0"  SelectedItem="{Binding Profile}" ItemTemplate="{StaticResource ProfileItemTemplate}" ItemsSource="{Binding ElementName=MainWindow , Path=DataContext.Settings.ApplicationProfiles}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid Grid.Row="2" Grid.ColumnSpan="3" Height="Auto" VerticalAlignment="Bottom" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>
                            <ui:Button Appearance="Primary" Grid.Column="6" Width="Auto" IsEnabled="{Binding ElementName=ApplicationList, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}"  Height="Auto" Content="{x:Static pres:ProjectLocales.LaunchApplication}" Command="{Binding StartApplicationCommand}" CommandParameter="{Binding ElementName=ApplicationList, Path=SelectedItem}"  Margin="5,5,10,10"/>
                            <ui:Button Grid.Column="1" Command="{Binding AddAssignmentCommand}" Padding="10,6" Margin="10,5,5,10" Height="Auto"><ui:SymbolIcon Symbol="Add24"/></ui:Button>
                            <ui:Button Grid.Column="2" Command="{Binding RemoveAssignmentCommand}" CommandParameter="{Binding ElementName=ApplicationList, Path=SelectedItem}"  Height="Auto" IsEnabled="{Binding ElementName=ApplicationList, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}" Padding="10,6"  Margin="5,5,5,10"><ui:SymbolIcon Symbol="Subtract24"/></ui:Button>

                            <ui:Button Grid.Column="3" Command="{Binding EditApplicationCommand}" CommandParameter="{Binding ElementName=ApplicationList, Path=SelectedItem}"  IsEnabled="{Binding ElementName=ApplicationList, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}" Padding="10,6"  Margin="10,5,5,10" Height="Auto"><ui:SymbolIcon Symbol="Edit24"/></ui:Button>

                            <ui:Button Grid.Column="4" Command="{Binding MoveAssignmentUpCommand}" CommandParameter="{Binding ElementName=ApplicationList, Path=SelectedItem}"  Margin="10,5,5,10" IsEnabled="{Binding ElementName=ApplicationList, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}" Padding="10,6" Height="Auto"><ui:SymbolIcon Symbol="ArrowUp24"/></ui:Button>
                            <ui:Button Grid.Column="5" Command="{Binding MoveAssignmentDownCommand}" CommandParameter="{Binding ElementName=ApplicationList, Path=SelectedItem}"   IsEnabled="{Binding ElementName=ApplicationList, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}"   Margin="5,5,5,10" Padding="10,6" Height="Auto"><ui:SymbolIcon Symbol="ArrowDown24"/></ui:Button>


                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static pres:ProjectLocales.Displays}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <local:MonitorManagerView   DataContext="{x:Static dsp:DisplayManagerHandler.Instance}"  IsEnabled="{Binding Settings.GlobalAutoActions, Converter={StaticResource InvertBooleanConverter}}"/>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static pres:ProjectLocales.Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>

                        <Grid  >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <local:UserAppSettingsView     DataContext="{Binding ElementName=MainWindow , Path=DataContext.Settings}" />
                            </ScrollViewer>

                        </Grid>
                </TabItem>
            </TabControl>
            <Button Grid.Row="1" Grid.Column="0" Content="{x:Static pres:ProjectLocales.Info}"  Command="{Binding ShowInfoCommand}" Height="Auto"  HorizontalAlignment="Left" Width="Auto" VerticalAlignment="Top" Margin="5" />
            <Button Grid.Row="1" Grid.Column="1" Content="{x:Static pres:ProjectLocales.Logs}"  Command="{Binding ShowLogsCommand}" Height="Auto"  HorizontalAlignment="Left" Width="Auto" VerticalAlignment="Top" Margin="5" />
            <Button   Grid.Row="1" Grid.Column="3"  Command="{Binding BuyBeerCommand}" Content="{x:Static pres:ProjectLocales.BuyBeer}" Margin="5" Height="Auto"  >
                <Button.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource DefaultButton}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BeerButton"  Height="Auto" Width="Auto" BorderBrush="{TemplateBinding Background}" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="{StaticResource DefaultCornerRadius}">
                                        <Grid >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding Converter={StaticResource  BitmapToBitmapImageConverter}, Source={x:Static pres:ProjectLocales.beer}}" Stretch="Fill"  Margin="5"   Height="{TemplateBinding FontSize}" />
                                            <TextBlock Grid.Column="1"   FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Background="Transparent" Margin="5,0" Foreground="{TemplateBinding Foreground}" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>

            </Button>
            <Button Grid.Row="1" Grid.Column="5" Content="{x:Static pres:ProjectLocales.Shutdown}"  Command="{Binding ShutdownCommand}" Height="Auto"  HorizontalAlignment="Left" Width="Auto" Margin="5" VerticalAlignment="Top" />
            <Grid  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Height="20" VerticalAlignment="Bottom" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock  Text="{Binding Path=Version, Mode=OneWay,  StringFormat= V\{0\} }"  Width="Auto" Margin="5,0"  Grid.Row="1"  Grid.Column="0"  HorizontalAlignment="Left" VerticalAlignment="Center"  />

                <Button  Grid.Column="1" Padding="0"  Command="{Binding ShowLicenseCommand}" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" Margin="5,0" HorizontalAlignment="Left" >
                    <Button.Resources>
                        <Style TargetType="Button"/>
                    </Button.Resources>
                    <TextBlock  Text="{x:Static pres:ProjectLocales.License}" Width="Auto" Margin="0"  Grid.Row="1"  Grid.Column="1"  Height="Auto" HorizontalAlignment="Right" TextDecorations="{x:Null}" VerticalAlignment="Center" >
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.MenuHighlightColorKey}}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Button>
            </Grid>

        </Grid>

    </Grid>

</corewpf:MainWindowBase>

