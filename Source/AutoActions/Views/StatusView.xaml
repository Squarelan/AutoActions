<UserControl x:Name="StatusViewControl"  x:Class="AutoActions.Views.StatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AutoActions.Views"
             xmlns:root="clr-namespace:AutoActions"
             xmlns:pres="clr-namespace:AutoActions.ProjectResources;assembly=AutoActions.ProjectResources"
             d:DataContext="{d:DesignInstance root:AutoActionsDaemon, IsDesignTimeCreatable=True}"
             Background="Transparent"
             mc:Ignorable="d" MinHeight="200" MinWidth="229.498">

    <UserControl.Resources>
        <DataTemplate x:Key="ActionShortcutItemTemplate" DataType="ProfileActionShortcut">
            <Grid Margin="4" Width="250">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBlock FontTypography="Body" TextTrimming="CharacterEllipsis" Grid.Column="0" VerticalAlignment="Center" ToolTip="{Binding ShortcutName}" Text="{Binding ShortcutName}" Margin="4,0"/>
                <ui:Button Grid.Column="1" Appearance="Primary" Padding="8,4" Command="{Binding RunActionCommand}">
                    <ui:SymbolIcon Symbol="Play24" />
                </ui:Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="ApplicationTemplate" DataType="ApplicationProfileAssignment">
            <Grid MaxWidth="275" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="40" Height="40" Grid.Column="0" CornerRadius="6" Background="{DynamicResource IconBackgroundBrush}">
                    <Border CornerRadius="6" Margin="1">
                        <Border.Background>
                            <ImageBrush Stretch="Fill" ImageSource="{Binding Application.Icon, Converter={StaticResource BitmapToBitmapImageConverter}}"/>
                        </Border.Background>
                    </Border>
                </Border>
                <ui:TextBlock FontTypography="Body" ToolTip="{Binding Application.DisplayName}" Grid.Column="1" Text="{Binding Application.DisplayName}" Margin="10,0" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <ui:Button Grid.Column="2" Appearance="Primary" Padding="8,4" Command="{Binding ElementName=StatusViewControl, Path=DataContext.StartApplicationCommand}" CommandParameter="{Binding}">
                    <ui:SymbolIcon Symbol="Play24" />
                </ui:Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="ProfileActionTemplate" DataType="IProfileAction">
            <Grid MinWidth="100" Width="300" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ui:TextBlock FontTypography="BodyStrong" Grid.Row="0" Text="{Binding ActionTypeName}" Margin="4,1" HorizontalAlignment="Left"/>
                <ui:TextBlock FontTypography="Caption" Foreground="{DynamicResource SubtleForegroundBrush}" Grid.Row="1" Text="{Binding ActionDescription}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ActionDescription}" Margin="4,0,0,4" HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Applications (left column, spans down) -->
        <ui:TextBlock FontTypography="Subtitle" Grid.Row="0" Grid.Column="0" Text="{x:Static pres:ProjectLocales.Applications}" Margin="6,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <ui:Card Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Margin="6" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AppSummaryList" BorderThickness="0" Background="Transparent" ItemsSource="{Binding Settings.ApplicationProfileAssignments}" ItemTemplate="{StaticResource ApplicationTemplate}" HorizontalAlignment="Stretch"/>
            </ScrollViewer>
        </ui:Card>

        <!-- Status (right column, top) -->
        <ui:TextBlock FontTypography="Subtitle" Grid.Row="0" Grid.Column="1" Text="{x:Static pres:ProjectLocales.Status}" Margin="6,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <ui:Card Grid.Row="1" Grid.Column="1" Margin="6" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ui:TextBlock FontTypography="BodyStrong" Grid.Row="0" Grid.Column="0" Text="{x:Static pres:ProjectLocales.HDR}" Margin="4,8" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <ui:ToggleSwitch Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,4" IsEnabled="False" IsChecked="{Binding HDRIsActive}"/>

                <ui:TextBlock FontTypography="BodyStrong" Grid.Row="1" Grid.Column="0" Margin="4,8" HorizontalAlignment="Left" Text="{x:Static pres:ProjectLocales.CurrentApplication}" VerticalAlignment="Center"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="12,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" Grid.Column="0" CornerRadius="6" Background="{DynamicResource IconBackgroundBrush}">
                        <Border CornerRadius="6" Margin="1">
                            <Border.Background>
                                <ImageBrush Stretch="Fill" ImageSource="{Binding CurrentApplication.Icon, Converter={StaticResource BitmapToBitmapImageConverter}}"/>
                            </Border.Background>
                        </Border>
                    </Border>
                    <ui:TextBlock FontTypography="Body" Grid.Column="1" Text="{Binding CurrentApplication.DisplayName , FallbackValue={x:Static pres:ProjectLocales.NoApplication}}" TextAlignment="Left" Margin="10,0" VerticalAlignment="Center"/>
                </Grid>

                <ui:TextBlock FontTypography="BodyStrong" Grid.Row="2" Grid.Column="0" Margin="4,8" HorizontalAlignment="Left" Text="{x:Static pres:ProjectLocales.CurrentProfile}" VerticalAlignment="Center"/>
                <ui:TextBlock FontTypography="Body" Grid.Row="2" Grid.Column="1" Margin="12,4" Text="{Binding CurrentProfile.Name , FallbackValue={x:Static pres:ProjectLocales.NoProfile}}" TextAlignment="Left" VerticalAlignment="Center"/>

                <ui:TextBlock FontTypography="BodyStrong" Grid.Row="3" Grid.Column="0" Margin="4,8" HorizontalAlignment="Left" Text="{x:Static pres:ProjectLocales.LastActions}" VerticalAlignment="Top"/>
                <ListView Grid.Row="3" Grid.Column="1" x:Name="LastActionsList" BorderThickness="0" Background="Transparent" Margin="8,4" MinHeight="60" ItemContainerStyle="{StaticResource ListBoxItemStyle}" ItemsPanel="{StaticResource WrapPanelTemplate}" ItemsSource="{Binding LastActions}" ItemTemplate="{StaticResource ProfileActionTemplate}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </ui:Card>

        <!-- Action shortcuts (right column, bottom) -->
        <ui:TextBlock FontTypography="Subtitle" Grid.Row="2" Grid.Column="1" Text="{x:Static pres:ProjectLocales.ActionShortcuts}" Margin="6,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <ui:Card Grid.Row="3" Grid.Column="1" Margin="6" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <ListView x:Name="ActionsList" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource ListBoxItemStyle}" ItemsPanel="{StaticResource WrapPanelTemplate}" ItemsSource="{Binding Settings.ActionShortcuts}" ItemTemplate="{StaticResource ActionShortcutItemTemplate}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </ui:Card>
    </Grid>
</UserControl>
