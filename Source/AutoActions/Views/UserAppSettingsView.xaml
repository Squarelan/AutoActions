<UserControl x:Class="AutoActions.Views.UserAppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AutoActions.Views"
             xmlns:root="clr-namespace:AutoActions"
             xmlns:pres="clr-namespace:AutoActions.ProjectResources;assembly=AutoActions.ProjectResources"
             d:DataContext="{d:DesignInstance root:UserAppSettings, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" MinHeight="200" MinWidth="229.498" >

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:TextBlock FontTypography="Subtitle" Grid.Column="0" Grid.Row="0" Margin="6,4" Text="{x:Static pres:ProjectLocales.Settings}"/>
        <ui:TextBlock FontTypography="Subtitle" Grid.Column="1" Grid.Row="0" Margin="6,4" Text="{x:Static pres:ProjectLocales.ActionShortcuts}"/>

        <ui:Card Grid.Row="1" Grid.Column="0" Margin="6" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Width="Auto" Height="Auto">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.AutoStart}" Grid.Column="0" Grid.Row="0" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.StartToTray}" Grid.Column="0" Grid.Row="1" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.MinimizeToTray}" Grid.Column="0" Grid.Row="2" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.CreateLogFile}" Grid.Column="0" Grid.Row="3" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.CheckForNewVersion}" Grid.Column="0" Grid.Row="4" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.AutoUpdate}" Grid.Column="0" Grid.Row="5" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.HideSplashScreenOnStartup}" Grid.Column="0" Grid.Row="6" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.HideSplashScreenOnUpdate}" Grid.Column="0" Grid.Row="7" Margin="6,6" VerticalAlignment="Center"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.GlobalAutoHDR}" Grid.Column="0" Grid.Row="8" Margin="6,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.DefaultProfile}" Grid.Column="0" Grid.Row="9" Margin="6,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ui:TextBlock FontTypography="Body" Text="{x:Static pres:ProjectLocales.Language}" Grid.Column="0" Grid.Row="10" Margin="6,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <ui:ToggleSwitch IsChecked="{Binding AutoStart}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding StartMinimizedToTray}" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding CloseToTray}" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding CreateLogFile}" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding CheckForNewVersion}" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding AutoUpdate}" IsEnabled="{Binding CheckForNewVersion}" Grid.Column="1" Grid.Row="5" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding HideSplashScreenOnStartup}" Grid.Column="1" Grid.Row="6" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding HideSplashScreenOnAutoUpdate}" IsEnabled="{Binding AutoUpdate}" Grid.Column="1" Grid.Row="7" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>
                    <ui:ToggleSwitch IsChecked="{Binding GlobalAutoActions}" Grid.Column="1" Grid.Row="8" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4"/>

                    <ComboBox Grid.Column="1" Grid.Row="9" MaxWidth="250" MinWidth="180" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4" SelectedValuePath="Name" DisplayMemberPath="Name" SelectedValue="{Binding DefaultProfile, Mode=TwoWay}" SelectedItem="{Binding DefaultProfile, Mode=TwoWay}" ItemsSource="{Binding ApplicationProfiles}"/>
                    <ComboBox Grid.Column="1" Grid.Row="10" MaxWidth="250" MinWidth="180" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,4" SelectedValuePath="CultureName" DisplayMemberPath="DisplayName" SelectedValue="{Binding Language, Mode=TwoWay}" ItemsSource="{Binding AvailableLanguages}" SelectionChanged="LanguageComboBox_SelectionChanged"/>
                </Grid>
            </ScrollViewer>
        </ui:Card>

        <local:ActionShortcutManagerView Grid.Row="1" Grid.Column="1" />

    </Grid>
</UserControl>
